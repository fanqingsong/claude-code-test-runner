# Test Case Service Environment Configuration

# ============================================================================
# Application Configuration
# ============================================================================
APP_NAME=Test Case Service
APP_VERSION=1.0.0
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8001

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL Database URL
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://cc_test_user:${POSTGRES_PASSWORD}@postgres:5432/claude_code_tests

# Database Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ============================================================================
# Security Configuration
# ============================================================================
# JWT Secret Key (must match the main SECRET_KEY)
SECRET_KEY=${SECRET_KEY}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Token Configuration
TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# CORS Configuration
# ============================================================================
# Allowed origins for cross-origin requests
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8013"]

# CORS Methods
CORS_METHODS=["GET","POST","PUT","DELETE","PATCH","OPTIONS"]

# CORS Headers
CORS_HEADERS=["*"]

# ============================================================================
# API Configuration
# ============================================================================
# API Prefix
API_V1_PREFIX=/api/v1

# API Documentation
DOCS_URL=/api/docs
REDOC_URL=/api/redoc
OPENAPI_URL=/api/openapi.json

# ============================================================================
# Test Case Management
# ============================================================================
# Maximum test steps per test definition
MAX_TEST_STEPS=100

# Maximum test definition name length
MAX_NAME_LENGTH=255

# Maximum test description length
MAX_DESCRIPTION_LENGTH=1000

# Test versioning configuration
ENABLE_VERSIONING=true
MAX_VERSIONS_PER_TEST=50

# ============================================================================
# Pagination Configuration
# ============================================================================
# Default page size for list endpoints
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Access logging
ENABLE_ACCESS_LOG=true
ACCESS_LOG_FORMAT=%(h)s %(l)s %(u)s %(t)s "%(r)s" %(s)s %(b)s %(D)s

# ============================================================================
# Rate Limiting (Optional)
# ============================================================================
# Enable rate limiting
ENABLE_RATE_LIMITING=false

# Rate limits (per minute)
RATE_LIMIT_GET=100
RATE_LIMIT_POST=50
RATE_LIMIT_PUT=50
RATE_LIMIT_DELETE=20

# ============================================================================
# Background Tasks (Optional)
# ============================================================================
# Enable background task processing
ENABLE_BACKGROUND_TASKS=false

# Task queue configuration
TASK_QUEUE_URL=redis://:CHANGE_THIS@redis:6379/0
TASK_RESULT_BACKEND=redis://:CHANGE_THIS@redis:6379/0

# ============================================================================
# Monitoring & Health Checks
# ============================================================================
# Enable health check endpoint
HEALTH_CHECK_ENABLED=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# ============================================================================
# Development Settings
# ============================================================================
# Development mode
ENVIRONMENT=development

# Auto-reload on code changes
RELOAD=false

# Debug toolbar
DEBUG_TOOLBAR=false

# ============================================================================
# Production Settings
# ============================================================================
# When ENVIRONMENT=production, these settings are recommended:
# DEBUG=false
# RELOAD=false
# LOG_LEVEL=WARNING
# ENABLE_RATE_LIMITING=true
# CORS_ORIGINS=["https://your-production-domain.com"]