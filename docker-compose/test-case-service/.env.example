# Application
APP_NAME=Test Case Service
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8001

# Database
DATABASE_URL=postgresql+asyncpg://cc_test_user:${POSTGRES_PASSWORD}@postgres:5432/claude_code_tests

# Security
SECRET_KEY=${SECRET_KEY}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
