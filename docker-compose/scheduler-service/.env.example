# Scheduler Service Environment Configuration

# ============================================================================
# Application Configuration
# ============================================================================
APP_NAME=Scheduler Service
APP_VERSION=1.0.0
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8002

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL Database URL
DATABASE_URL=postgresql+asyncpg://cc_test_user:${POSTGRES_PASSWORD}@postgres:5432/claude_code_tests

# ============================================================================
# Redis Configuration
# ============================================================================
# Redis URL for Celery broker and backend
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ============================================================================
# Celery Task Queue Configuration
# ============================================================================
# Celery Broker URL
CELERY_BROKER_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# Celery Result Backend
CELERY_RESULT_BACKEND=redis://:${REDIS_PASSWORD}@redis:6379/0

# Celery Worker Configuration
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_LOG_LEVEL=info
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_TASK_TIME_LIMIT=600

# Task Queue Configuration
CELERY_TASK_ROUTES={
    "app.tasks.test_execution.execute_test": {
        "queue": "test_execution",
        "routing_key": "test_execution.execute"
    }
}

# ============================================================================
# Security Configuration
# ============================================================================
# JWT Secret Key (must match the main SECRET_KEY)
SECRET_KEY=${SECRET_KEY}
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# CORS Configuration
# ============================================================================
# Allowed origins for cross-origin requests
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8013"]

# ============================================================================
# Test Execution Configuration
# ============================================================================
# Playwright Browser Configuration
PLAYWRIGHT_HEADLESS=true
SCREENSHOT_DIR=/app/screenshots
TEST_TIMEOUT=300000

# Browser Launch Options
BROWSER_LAUNCH_TIMEOUT=30000
BROWSER_CONTEXT_TIMEOUT=10000

# Page Default Settings
PAGE_DEFAULT_TIMEOUT=30000
PAGE_NAVIGATION_TIMEOUT=30000

# ============================================================================
# AI Services Configuration (Claude/GLM Integration)
# ============================================================================
# Claude AI / GLM API Configuration for AI-powered test execution
# These are optional - the system will use rule-based interpretation if not provided

# Option 1: Use Anthropic Claude (Original)
# Get your API key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-actual-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Option 2: Use GLM (智谱AI) Compatible API (Recommended for Chinese)
# Get your API key from: https://open.bigmodel.cn/
# GLM provides excellent Chinese language support and competitive pricing
ANTHROPIC_API_KEY=your-glm-api-key-here
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# API Configuration
API_TIMEOUT_MS=300000
API_MAX_RETRIES=3
API_RETRY_DELAY=1000

# Claude Model Configuration
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=1024
CLAUDE_TEMPERATURE=0.0

# AI Interpretation Settings
ENABLE_AI_INTERPRETATION=true
AI_FALLBACK_TO_RULES=true

# ============================================================================
# Task Execution Configuration
# ============================================================================
# Maximum concurrent test executions
MAX_CONCURRENT_TESTS=3

# Task result retention (days)
TASK_RESULT_RETENTION_DAYS=30

# Test execution priority levels
PRIORITY_HIGH=10
PRIORITY_MEDIUM=5
PRIORITY_LOW=1

# ============================================================================
# Scheduling Configuration
# ============================================================================
# Enable scheduled test execution
ENABLE_SCHEDULED_EXECUTION=true

# Default schedule cron expression (every hour)
DEFAULT_SCHEDULE="0 * * * *"

# Schedule configuration file path
SCHEDULE_CONFIG_FILE=/app/config/schedules.yaml

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Task execution logging
ENABLE_TASK_LOGGING=true
TASK_LOG_LEVEL=DEBUG
TASK_LOG_FORMAT=detailed

# API call logging
ENABLE_API_LOGGING=true
API_LOG_LEVEL=INFO

# ============================================================================
# Monitoring & Health Checks
# ============================================================================
# Enable health check endpoint
HEALTH_CHECK_ENABLED=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# Worker health check
WORKER_HEALTH_CHECK_INTERVAL=60

# ============================================================================
# Performance Configuration
# ============================================================================
# Database connection pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Redis connection pool
REDIS_POOL_SIZE=10
REDIS_MAX_CONNECTIONS=50

# ============================================================================
# Error Handling Configuration
# ============================================================================
# Maximum retry attempts for failed operations
MAX_RETRY_ATTEMPTS=3

# Retry delay (seconds)
RETRY_DELAY=5

# Task failure handling
TASK_FAILURE_NOTIFICATION=true
TASK_FAILURE_EMAIL=alerts@example.com

# ============================================================================
# Development Settings
# ============================================================================
# Development mode
ENVIRONMENT=development

# Enable debug output
DEBUG_TASK_EXECUTION=false
DEBUG_AI_INTERPRETATION=false

# Test data cleanup
CLEANUP_TEST_DATA=true
CLEANUP_INTERVAL_HOURS=24

# ============================================================================
# Production Settings
# ============================================================================
# When ENVIRONMENT=production, these settings are recommended:
# DEBUG=false
# LOG_LEVEL=WARNING
# PLAYWRIGHT_HEADLESS=true
# ENABLE_AI_INTERPRETATION=true
# API_TIMEOUT_MS=120000
# MAX_CONCURRENT_TESTS=5
# CLEANUP_TEST_DATA=false

# ============================================================================
# Claude Code Plugin Configuration
# ============================================================================
# Disable non-essential traffic for Claude Code plugins
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Git timeout for plugin operations (milliseconds)
CLAUDE_CODE_PLUGIN_GIT_TIMEOUT_MS=300000

# ============================================================================
# Feature Flags
# ============================================================================
# Enable AI-powered test execution (requires ANTHROPIC_API_KEY)
ENABLE_AI_TEST_EXECUTION=true

# Enable parallel test execution
ENABLE_PARALLEL_EXECUTION=false
MAX_PARALLEL_TESTS=3

# Enable test result caching
ENABLE_TEST_CACHING=true
CACHE_TTL_SECONDS=3600

# Enable detailed error reporting
ENABLE_ERROR_REPORTING=true

# ============================================================================
# Notes
# ============================================================================
# 1. AI services are optional - system works with rule-based fallback
# 2. GLM AI recommended for Chinese language support
# 3. Adjust timeout values based on your test complexity
# 4. Monitor API usage when using AI services to control costs
# 5. Use different API keys for development and production
# 6. Enable ENABLE_PARALLEL_EXECUTION only if you have sufficient API quota