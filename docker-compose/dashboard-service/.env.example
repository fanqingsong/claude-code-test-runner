# Dashboard Service Environment Configuration

# ============================================================================
# Application Configuration
# ============================================================================
# Application Name
APP_NAME=Claude Code Test Runner Dashboard
APP_VERSION=1.0.0

# Node Environment
NODE_ENV=production

# Server Configuration
PORT=8003
HOST=0.0.0.0

# ============================================================================
# Database Configuration
# ============================================================================
# PostgreSQL Database Connection
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=claude_code_tests
POSTGRES_USER=cc_test_user
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# Database Connection Timeout
DB_CONNECTION_TIMEOUT=10000
DB_QUERY_TIMEOUT=30000

# ============================================================================
# API Configuration
# ============================================================================
# Backend API Endpoints
TEST_CASE_SERVICE_URL=http://test-case-service:8001
SCHEDULER_SERVICE_URL=http://scheduler-service:8002
DASHBOARD_SERVICE_URL=http://dashboard-service:8003

# API Timeout Configuration
API_TIMEOUT_MS=30000
API_RETRY_ATTEMPTS=3
API_RETRY_DELAY_MS=1000

# API Version
API_VERSION=v1

# ============================================================================
# Security Configuration
# ============================================================================
# JWT Secret Key (must match the main SECRET_KEY)
SECRET_KEY=${SECRET_KEY}

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Token Refresh Configuration
REFRESH_TOKEN_ENABLED=false
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# CORS Configuration
# ============================================================================
# Allowed origins for cross-origin requests
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000","http://localhost:8013"]

# CORS Credentials
CORS_CREDENTIALS=true

# CORS Max Age
CORS_MAX_AGE=86400

# ============================================================================
# Frontend Configuration
# ============================================================================
# Frontend Build Configuration
VITE_PORT=5173
VITE_HOST=localhost

# Build Configuration
NODE_ENV=production
VITE_MODE=production

# Asset Optimization
ENABLE_MINIFICATION=true
ENABLE_SOURCE_MAPS=false

# ============================================================================
# Dashboard Configuration
# ============================================================================
# Dashboard Refresh Interval (milliseconds)
DASHBOARD_REFRESH_INTERVAL=30000

# Dashboard Data Retention (days)
DASHBOARD_DATA_RETENTION_DAYS=30

# Maximum items per page
MAX_ITEMS_PER_PAGE=100

# Chart Configuration
ENABLE_CHARTS=true
CHART_REFRESH_INTERVAL=60000

# ============================================================================
# Test Management Configuration
# ============================================================================
# Maximum test steps per test
MAX_TEST_STEPS=50

# Test name validation
TEST_NAME_MIN_LENGTH=1
TEST_NAME_MAX_LENGTH=255

# Test description validation
TEST_DESCRIPTION_MAX_LENGTH=1000

# Tag configuration
MAX_TAGS_PER_TEST=20
MAX_TAG_LENGTH=50

# Environment variable limits
MAX_ENV_VARS=20
MAX_ENV_VAR_KEY_LENGTH=50
MAX_ENV_VAR_VALUE_LENGTH=200

# ============================================================================
# Real-time Updates Configuration
# ============================================================================
# Enable WebSocket for real-time updates
ENABLE_WEBSOCKET=true

# WebSocket heartbeat interval (milliseconds)
WEBSOCKET_HEARTBEAT_INTERVAL=30000

# Real-time test status updates
ENABLE_REAL_TIME_STATUS=true
STATUS_UPDATE_INTERVAL=5000

# ============================================================================
# File Upload Configuration
# ============================================================================
# Maximum file upload size (bytes)
MAX_FILE_UPLOAD_SIZE=10485760

# Allowed file types
ALLOWED_FILE_TYPES=[".json",".yaml",".yml",".txt"]

# Upload directory
UPLOAD_DIR=/app/uploads

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level
LOG_LEVEL=info

# Log format
LOG_FORMAT=json

# Access logging
ENABLE_ACCESS_LOG=true

# Error logging
ENABLE_ERROR_LOG=true

# Log file location
LOG_DIR=/app/logs

# ============================================================================
# Monitoring & Health Checks
# ============================================================================
# Enable health check endpoint
HEALTH_CHECK_ENABLED=true

# Health check interval (seconds)
HEALTH_CHECK_INTERVAL=30

# Metrics collection
ENABLE_METRICS=false
METRICS_PORT=9090

# Performance monitoring
ENABLE_PERFORMANCE_MONITORING=true

# ============================================================================
# Cache Configuration
# ============================================================================
# Enable response caching
ENABLE_CACHE=true

# Cache TTL (seconds)
CACHE_TTL_SECONDS=300

# Cache configuration
CACHE_MAX_SIZE=100

# ============================================================================
# Rate Limiting Configuration
# ============================================================================
# Enable rate limiting
ENABLE_RATE_LIMITING=false

# Rate limits (per minute)
RATE_LIMIT_GET=100
RATE_LIMIT_POST=50
RATE_LIMIT_PUT=50
RATE_LIMIT_DELETE=20

# ============================================================================
# Session Configuration
# ============================================================================
# Session secret
SESSION_SECRET=${SECRET_KEY}

# Session timeout (milliseconds)
SESSION_TIMEOUT_MS=3600000

# Session max age
SESSION_MAX_AGE=86400000

# ============================================================================
# Feature Flags
# ============================================================================
# Enable test execution from dashboard
ENABLE_TEST_EXECUTION=true

# Enable test editing
ENABLE_TEST_EDITING=true

# Enable test deletion
ENABLE_TEST_DELETION=true

# Enable test history
ENABLE_TEST_HISTORY=true

# Enable dashboard statistics
ENABLE_DASHBOARD_STATS=true

# Enable AI-powered features
ENABLE_AI_FEATURES=true

# ============================================================================
# UI Configuration
# ============================================================================
# Default page size for pagination
DEFAULT_PAGE_SIZE=20

# Maximum page size
MAX_PAGE_SIZE=100

# Theme configuration
DEFAULT_THEME=light
ENABLE_THEME_SWITCHING=true

# Language configuration
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=["en","zh"]

# ============================================================================
# Development Settings
# ============================================================================
# Development mode
ENVIRONMENT=development

# Enable hot reload
ENABLE_HOT_RELOAD=true

# Enable debug tools
ENABLE_DEBUG_TOOLS=false

# Source maps
ENABLE_SOURCE_MAPS=true

# ============================================================================
# Production Settings
# ============================================================================
# When NODE_ENV=production, these settings are recommended:
# ENABLE_HOT_RELOAD=false
# ENABLE_DEBUG_TOOLS=false
# ENABLE_SOURCE_MAPS=false
# LOG_LEVEL=warn
# MAX_FILE_UPLOAD_SIZE=5242880
# ENABLE_RATE_LIMITING=true

# ============================================================================
# Plugin Configuration
# ============================================================================
# Disable non-essential traffic for Claude Code plugins
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Git timeout for plugin operations (milliseconds)
CLAUDE_CODE_PLUGIN_GIT_TIMEOUT_MS=300000

# ============================================================================
# External Services
# ============================================================================
# External API endpoints (if any)
EXTERNAL_API_TIMEOUT_MS=10000

# Webhook configuration (if any)
WEBHOOK_ENABLED=false
WEBHOOK_TIMEOUT_MS=5000
WEBHOOK_RETRY_ATTEMPTS=3

# ============================================================================
# Notes
# ============================================================================
# 1. This is the frontend dashboard service
# 2. It connects to test-case-service and scheduler-service
# 3. All sensitive data should be stored in environment variables
# 4. Update CORS_ORIGINS when deploying to production
# 5. Use different SECRET_KEY for each environment
# 6. Monitor file upload sizes to prevent abuse
# 7. Adjust cache settings based on your data change frequency