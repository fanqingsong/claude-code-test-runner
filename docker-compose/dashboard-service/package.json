{
  "name": "dashboard-service",
  "version": "1.0.0",
  "description": "Dashboard service for Claude Code Tests - connects to PostgreSQL",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "dev:full": "concurrently \"npm run dev\" \"npm run frontend:dev\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "ejs": "^3.1.9",
    "ws": "^8.16.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/ws": "^8.5.10",
    "concurrently": "^8.2.0"
  }
}
