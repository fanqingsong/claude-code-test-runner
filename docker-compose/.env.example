# Claude Code Test Runner - Environment Configuration Example
# Copy this file to .env and update with your actual values

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
POSTGRES_DB=claude_code_tests
POSTGRES_USER=cc_test_user
POSTGRES_PASSWORD=CHANGE_THIS_GENERATE_SECURE_PASSWORD_MIN_32_CHARS

# ============================================================================
# Redis Configuration
# ============================================================================
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD

# ============================================================================
# Security Configuration
# ============================================================================
# JWT Secret Key - Generate a secure random string for production
SECRET_KEY=change-this-secret-key-in-production-generate-secure-random-string

# Admin User Password
ADMIN_PASSWORD=admin

# JWT Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# ============================================================================
# AI Services Configuration
# ============================================================================
# Claude AI / GLM API Configuration for AI-powered test execution
# These are optional - the system will use rule-based interpretation if not provided

# Option 1: Use Anthropic Claude (Original)
# Get your API key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-actual-key-here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Option 2: Use GLM (智谱AI) Compatible API
# Get your API key from: https://open.bigmodel.cn/
# GLM provides excellent Chinese language support and competitive pricing
ANTHROPIC_API_KEY=your-glm-api-key-here
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic

# API Configuration
API_TIMEOUT_MS=300000

# Note: If ANTHROPIC_API_KEY is not set, the system will automatically use
# intelligent rule-based interpretation instead of AI services.

# ============================================================================
# Service Ports
# ============================================================================
# Test Case Service API
TEST_CASE_SERVICE_PORT=8011

# Scheduler Service API
SCHEDULER_SERVICE_PORT=8012

# Dashboard Service
DASHBOARD_SERVICE_PORT=8013

# ============================================================================
# Environment Configuration
# ============================================================================
ENVIRONMENT=development

# Debug Mode (set to "true" for development, "false" for production)
DEBUG=false

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins for API access
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://localhost:8013

# ============================================================================
# Test Execution Configuration
# ============================================================================
# Playwright Browser Configuration
PLAYWRIGHT_HEADLESS=true
SCREENSHOT_DIR=/app/screenshots

# Test Execution Timeout (in milliseconds)
TEST_TIMEOUT=300000

# ============================================================================
# Celery Task Queue Configuration
# ============================================================================
CELERY_BROKER_URL=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0
CELERY_RESULT_BACKEND=redis://:CHANGE_THIS_REDIS_PASSWORD@redis:6379/0

# Celery Worker Configuration
CELERY_WORKER_CONCURRENCY=2
CELERY_WORKER_LOG_LEVEL=info

# ============================================================================
# Docker Compose Configuration
# ============================================================================
# Docker Compose Project Name
COMPOSE_PROJECT_NAME=claude-code-test-runner

# Network Configuration
COMPOSE_NETWORK_NAME=test-network

# ============================================================================
# Optional Features
# ============================================================================
# Disable non-essential traffic for Claude Code plugins
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Git timeout for plugin operations (in milliseconds)
CLAUDE_CODE_PLUGIN_GIT_TIMEOUT_MS=300000

# ============================================================================
# Development Settings
# ============================================================================
# Log levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable detailed API logging
API_LOG_LEVEL=INFO

# Enable test execution logging
TEST_LOG_LEVEL=DEBUG

# ============================================================================
# Production Settings (uncomment for production use)
# ============================================================================
# ENVIRONMENT=production
# DEBUG=false
# PLAYWRIGHT_HEADLESS=true
# LOG_LEVEL=WARNING
# API_TIMEOUT_MS=120000

# ============================================================================
# Monitoring & Observability (Optional)
# ============================================================================
# Enable Prometheus metrics
# ENABLE_PROMETHEUS=false
# PROMETHEUS_PORT=9090

# Enable health check endpoints
HEALTH_CHECK_ENABLED=true

# ============================================================================
# Feature Flags
# ============================================================================
# Enable AI-powered test execution (requires ANTHROPIC_API_KEY)
ENABLE_AI_TEST_EXECUTION=true

# Enable test result caching
ENABLE_TEST_CACHING=true

# Enable parallel test execution
ENABLE_PARALLEL_EXECUTION=false
MAX_PARALLEL_TESTS=3

# ============================================================================
# Notes
# ============================================================================
# 1. Generate secure passwords using: openssl rand -base64 32
# 2. API keys are optional - system works with rule-based fallback
# 3. GLM AI recommended for Chinese language support
# 4. Adjust timeout values based on your test complexity
# 5. Monitor API usage when using AI services to control costs
# 6. Use different API keys for development and production environments

# ============================================================================
# Quick Start
# ============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Update passwords and API keys
# 3. Run: docker compose up -d
# 4. Access dashboard: http://localhost:8013
# 5. Run configuration check: ./verify_glm_config.sh